{
  "name": "@doc/api",
  "version": "0.0.1",
  "private": true,
  "description": "Defence Overseas CRM — Express API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch --env-file .env.development src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix"
  },
  "dependencies": {
    "@doc/shared": "workspace:*",
    "@supabase/supabase-js": "^2.45.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^8.5.2",
    "multer": "^2.2.0",
    "pdfkit": "^0.19.1",
    "pino": "^10.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.16.1",
    "@types/pdfkit": "^0.17.6",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.17.0",
    "typescript": "^5.5.4"
  }
}
